#supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# backend server
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# Gmail SMTP (use Gmail App Password, not your normal login password)
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# optional: protect /api/email/send with x-api-key
MAIL_API_KEY=123456789abcdef

# Supabase Admin (REQUIRED for signup verification & forgot password email flow)
# Get this from: Supabase Dashboard → Settings → API → service_role key (secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# mail & redirect settings
MAIL_FROM_NAME=ReMarket
SIGNUP_CONFIRM_PATH=/login
RESET_PASSWORD_PATH=/reset-password
SIGNUP_COOLDOWN_SECONDS=90
FORGOT_PASSWORD_COOLDOWN_SECONDS=60

# Payment gateways
PAYMENT_RETURN_URL=http://localhost:5173/payment/return
PAYMENT_NOTIFY_URL=http://localhost:4000/api/payment/ipn/momo

# MoMo sandbox
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_PARTNER_NAME=ReMarket
MOMO_STORE_ID=ReMarketStore
MOMO_REQUEST_TYPE=captureWallet
MOMO_CREATE_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_QUERY_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/query

# VNPAY sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_ENDPOINT=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_QUERY_ENDPOINT=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_VERSION=2.1.0
VNPAY_CURR_CODE=VND
VNPAY_LOCALE=vn
VNPAY_ORDER_TYPE=other
